{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/Documentation/(.*)",
      "dest": "/Documentation/$1"
    },
    {
      "src": "/documentation.html",
      "dest": "/documentation.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
